#!/bin/bash
# RESC Host Launcher — opens Terminal with the host process
# Edit these defaults:
CLIENT_IP="192.168.50.47"
WIDTH=1080
HEIGHT=1920
FPS=60
CODEC="--hevc"
PORT=9870

# Absolute path to binary
BIN="/Users/moyunfei/Downloads/personal/AGI/remote_extended_screen/mac-host/.build/release/remote-display-host"

if [ ! -f "$BIN" ]; then
    BIN="/Users/moyunfei/Downloads/personal/AGI/remote_extended_screen/mac-host/.build/debug/remote-display-host"
fi

if [ ! -f "$BIN" ]; then
    osascript -e 'display alert "RESC Host" message "Binary not found. Run:\ncd mac-host && swift build -c release"'
    exit 1
fi

# Launch in Terminal so output is visible and process responds properly
osascript -e "
tell application \"Terminal\"
    activate
    do script \"'$BIN' $WIDTH $HEIGHT $FPS $CODEC --client $CLIENT_IP --port $PORT\"
end tell
"
